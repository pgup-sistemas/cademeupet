# Copie este arquivo para ".env" e preencha os valores reais.
# Nunca versione o arquivo .env com segredos.

# Ambiente da aplicação (development ou production)
APP_ENV=production

# URL base do sistema
BASE_URL=https://cademeupet.pageup.net.br

# Banco de dados
DB_HOST=
DB_NAME=
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4

# Efí Bank (Pix)
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_PIX_KEY=
EFI_PIX_DESCRIPTION=Doação para Cadê Meu Pet?
EFI_PIX_NOTIFICATION_URL=https://cademeupet.pageup.net.br/api/efi-webhook.php
EFI_BASE_URL=https://api.efipay.com.br/api/
EFI_WEBHOOK_TOKEN=
EFI_BILLING_WEBHOOK_TOKEN=
EFI_CERTIFICATE_PATH=
EFI_SANDBOX=false

# E-mail transacional (Resend.com — https://resend.com/api-keys)
RESEND_API_KEY=re_COLOQUE_SUA_API_KEY_AQUI
EMAIL_FROM=noreply@cademeupet.pageup.net.br
EMAIL_FROM_NAME=Cadê Meu Pet?

# Credenciais administrativas padrão (usar apenas no setup inicial)
DEFAULT_ADMIN_EMAIL=admin@cademeupet.pageup.net.br
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_NAME=Administrador
DEFAULT_ADMIN_PHONE=
DEFAULT_ADMIN_CITY=Porto Velho
DEFAULT_ADMIN_STATE=RO

# Google Maps (obrigatório para mapa e geocoding)
GOOGLE_MAPS_API_KEY=

# EFI Bank - Configurações adicionais
EFI_CERTIFICATE_PASSWORD=
EFI_SPLIT_ENABLED=false
EFI_SPLIT_RULES_JSON=

# Debug (somente desenvolvimento)
DEBUG_DOACAO=false

# Flags temporárias (habilite apenas em desenvolvimento)
# DEFAULT_ADMIN_UNLOCK=true
# DEFAULT_ADMIN_RESET_PASSWORD=true
# DEFAULT_ADMIN_FORCE=true
