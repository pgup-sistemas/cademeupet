# Cadê Meu Pet? - Apache Configuration
# Subdomínio: cademeupet.pageup.net.br
# Diretório: /public_html/cademeupet

# Forçar UTF-8 em todos os arquivos de texto
AddDefaultCharset UTF-8
AddCharset UTF-8 .php .html .htm .css .js .json .xml .txt

<IfModule mod_rewrite.c>
    RewriteEngine On
    # LOCAL (subdiretório): RewriteBase /cademeupet/
    # PRODUÇÃO (raiz do domínio): RewriteBase /
    RewriteBase /cademeupet/

    # Força HTTPS em produção
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1
    RewriteCond %{REMOTE_ADDR} !^127\.0\.0\.1
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [L,R=301]

    # Include local env file (uncomment if you will upload `.htaccess.env` to the server and your host allows Include)
    # Include .htaccess.env

    # Ignorar arquivos e diretórios reais
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # API primeiro (para não interferir com outras regras)
    RewriteRule ^api/efi-billing-notification/?$ api/efi-billing-notification.php [L,QSA]
    RewriteRule ^api/efi-webhook/?$             api/efi-webhook.php [L,QSA]
    RewriteRule ^api/webhook-pix-admin/?$       api/webhook-pix-admin.php [L,QSA]
    RewriteRule ^api/status-doacao/?$           api/status-doacao.php [L,QSA]
    RewriteRule ^api/v1/anuncios/?$              api/v1/anuncios.php [L,QSA]
    RewriteRule ^api/v1/parceiros/?$             api/v1/parceiros.php [L,QSA]
    RewriteRule ^api/v1/ingestao/animais/?$      api/v1/ingestao/animais.php [L,QSA]

    # Rotas administrativas
    RewriteRule ^admin/?$ views/admin.php [L,QSA]
    RewriteRule ^admin/usuarios/?$ views/admin-usuarios.php [L,QSA]
    RewriteRule ^admin/financeiro/export/?$ views/admin-financeiro-export.php [L,QSA]
    RewriteRule ^admin/financeiro/?$ views/admin-financeiro.php [L,QSA]
    RewriteRule ^admin/parceiros/?$ views/admin-parceiros.php [L,QSA]
    RewriteRule ^admin/anuncios/?$ views/admin-anuncios.php [L,QSA]
    RewriteRule ^admin/config/?$ views/admin-config.php [L,QSA]
    RewriteRule ^admin/moderacao/?$ views/admin-moderacao.php [L,QSA]
    RewriteRule ^admin/denuncias/?$ views/admin-denuncias.php [L,QSA]
    RewriteRule ^admin/cancelamentos/?$ views/admin-cancelamentos.php [L,QSA]
    RewriteRule ^admin/depoimentos/?$ views/admin-depoimentos.php [L,QSA]
    RewriteRule ^admin/api-keys/?$ views/admin-api-keys.php [L,QSA]
    RewriteRule ^minha-conta/?$ views/minha-conta.php [L,QSA]

    # Rotas de parceiros (ordem importa!)
    RewriteRule ^parceiros/inscricao/?$ parceiros-inscricao.php [L,QSA]
    RewriteRule ^parceiros/?$ views/parceiros.php [L,QSA]
    RewriteRule ^parceiro/painel/?$ parceiro-painel.php [L,QSA]
    RewriteRule ^parceiro/perfil/?$ parceiro-perfil.php [L,QSA]
    RewriteRule ^parceiro/pagamento/?$ parceiro-pagamento.php [L,QSA]
    RewriteRule ^parceiro/abrir-pagamento/?$ parceiro-abrir-pagamento.php [L,QSA]
    RewriteRule ^parceiro/pix/?$ parceiro-pix.php [L,QSA]
    RewriteRule ^admin/parceiro-editar/?$ views/admin-parceiro-editar.php [L,QSA]
    RewriteRule ^parceiro/contrato/?$ views/parceiro-contrato-aceite.php [L,QSA]
    RewriteRule ^parceiro/contrato-pdf/?$ views/parceiro-contrato-pdf.php [L,QSA]

    # Perfil público de usuário
    RewriteRule ^usuario/(\d+)/?$ views/perfil-publico.php?id=$1 [L,QSA]

    # URL amigável para anúncios
    RewriteRule ^anuncio/(\d+)/?$ anuncio.php?id=$1 [L,QSA]
    # URL amigável para editar anúncio
    RewriteRule ^editar-anuncio/(\d+)/?$ editar-anuncio.php?id=$1 [L,QSA]
    RewriteRule ^sitemap\.xml$ sitemap.php [L,QSA]
    RewriteRule ^parceiro/cancelar/?$ parceiro-cancelar.php [L,QSA]
    RewriteRule ^parceiro/([^/]+)/?$ parceiro-publico.php?slug=$1 [L,QSA]

    # ─── Pet Love ───────────────────────────────────────────────────
    RewriteRule ^petlove/novo/?$                      views/petlove-novo.php [L,QSA]
    RewriteRule ^petlove/interesse/?$                 petlove-interesse.php [L,QSA]
    RewriteRule ^petlove/status/(\d+)/([a-z]+)/?$    petlove-status.php?id=$1&status=$2 [L,QSA]
    RewriteRule ^minha-conta/petlove/?$               views/minha-conta-petlove.php [L,QSA]
    RewriteRule ^petlove/(\d+)/?$                     views/petlove-detalhe.php?id=$1 [L,QSA]
    RewriteRule ^petlove/?$                           views/petlove.php [L,QSA]
    # ────────────────────────────────────────────────────────────────

    # Rotas principais do sistema
    RewriteRule ^cadastro/?$ views/cadastro.php [L,QSA]
    RewriteRule ^login/?$ views/login.php [L,QSA]
    RewriteRule ^logout/?$ views/logout.php [L,QSA]
    RewriteRule ^perfil/?$ views/perfil.php [L,QSA]
    RewriteRule ^busca/?$ views/busca.php [L,QSA]
    RewriteRule ^novo-anuncio/?$ views/novo-anuncio.php [L,QSA]
    RewriteRule ^meus-anuncios/?$ views/meus-anuncios.php [L,QSA]
    RewriteRule ^anuncio/?$ views/anuncio-detalhes.php [L,QSA]
    RewriteRule ^anuncio/editar/([0-9]+)/?$ views/editar-anuncio.php?id=$1 [L,QSA]
    RewriteRule ^favoritos/?$ views/favoritos.php [L,QSA]
    RewriteRule ^alertas/?$ views/alertas.php [L,QSA]
    RewriteRule ^mensagens/?$ views/mensagens.php [L,QSA]
    RewriteRule ^matches/?$ matches.php [L,QSA]
    RewriteRule ^triagem/conversa/?$ triagem-conversa.php [L,QSA]
    RewriteRule ^triagem/historico/?$ triagem-historico.php [L,QSA]
    RewriteRule ^triagem/?$ triagem.php [L,QSA]

    # Rotas de ação
    RewriteRule ^denunciar-anuncio/?$ denunciar-anuncio.php [L,QSA]
    RewriteRule ^excluir-anuncio/?$ views/excluir-anuncio.php [L,QSA]
    RewriteRule ^marcar-resolvido/?$ views/marcar-resolvido.php [L,QSA]
    RewriteRule ^marcar-ativo/?$ marcar-ativo.php [L,QSA]
    RewriteRule ^renovar-anuncio/?$ renovar-anuncio.php [L,QSA]
    RewriteRule ^favorito/toggle/?$ views/favorito_toggle.php [L,QSA]

    # Rotas de autenticação e email
    RewriteRule ^reenviar-confirmacao/?$ views/reenviar-confirmacao.php [L,QSA]
    RewriteRule ^confirmar-email/?$ confirmar-email.php [L,QSA]
    RewriteRule ^recuperar-senha/?$ views/recuperar-senha.php [L,QSA]
    RewriteRule ^resetar-senha/?$ views/resetar-senha.php [L,QSA]

    # Rotas de doação
    RewriteRule ^doar/?$ doar.php [L,QSA]
    RewriteRule ^doacao-pix/?$ doacao-pix.php [L,QSA]
    RewriteRule ^doacao-cancelar/?$ doacao-cancelar.php [L,QSA]
    RewriteRule ^transparencia/?$ views/transparencia.php [L,QSA]

    # Páginas institucionais
    RewriteRule ^ajuda/?$ views/ajuda.php [L,QSA]

    # Páginas de LGPD e Termos
    RewriteRule ^politica-privacidade/?$ views/paginas-estaticas/politica-privacidade.php [L,QSA]
    RewriteRule ^termos-uso/?$ views/paginas-estaticas/termos-uso.php [L,QSA]
    RewriteRule ^politica-cookies/?$ views/paginas-estaticas/politica-cookies.php [L,QSA]
    RewriteRule ^lgpd/?$ views/paginas-estaticas/lgpd.php [L,QSA]
    RewriteRule ^contato-dpo/?$ views/paginas-estaticas/contato-dpo.php [L,QSA]
</IfModule>

# Bloquear listagem de diretórios
Options -Indexes

# Proteger arquivos sensíveis (compatibilidade Apache 2.2/2.4)
<IfModule mod_authz_core.c>
    <FilesMatch "(^(config\.php|\.env|\.git.*|\.htaccess|\.htpasswd)$|\.(bak|old|tmp|orig|save|sql|log)$)">
        Require all denied
    </FilesMatch>
</IfModule>
<IfModule !mod_authz_core.c>
    <FilesMatch "(^(config\.php|\.env|\.git.*|\.htaccess|\.htpasswd)$|\.(bak|old|tmp|orig|save|sql|log)$)">
        Deny from all
    </FilesMatch>
</IfModule>

# Proteger certificados e chaves (PEM/P12/KEY)
<IfModule mod_authz_core.c>
    <FilesMatch "\.(pem|p12|key)$">
        Require all denied
    </FilesMatch>
</IfModule>
<IfModule !mod_authz_core.c>
    <FilesMatch "\.(pem|p12|key)$">
        Deny from all
    </FilesMatch>
</IfModule> 

# Proteger diretórios sensíveis
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(includes|config|vendor|\.git|secrets)/.*$ - [F,L]
</IfModule>

# Cache de assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# Compressão GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Headers de segurança
<IfModule mod_headers.c>
    # Prevenir XSS
    Header set X-XSS-Protection "1; mode=block"

    # Prevenir Clickjacking
    Header set X-Frame-Options "SAMEORIGIN"

    # Prevenir MIME sniffing
    Header set X-Content-Type-Options "nosniff"

    # Referrer Policy
    Header set Referrer-Policy "strict-origin-when-cross-origin"

    # HSTS — força HTTPS por 1 ano (ativar após confirmar HTTPS funcionando)
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Content Security Policy
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://maps.googleapis.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://kit.fontawesome.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://fonts.googleapis.com https://unpkg.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com https://ka-f.fontawesome.com; img-src 'self' data: blob: https://maps.gstatic.com https://maps.googleapis.com https://*.tile.openstreetmap.org https://unpkg.com; connect-src 'self' https://api.resend.com https://*.tile.openstreetmap.org; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self';"

    # Permissions Policy
    Header set Permissions-Policy "geolocation=(self), camera=(), microphone=()"

    # Remover informações do servidor
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# Configurações PHP (se permitido)
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value max_execution_time 300
    php_value max_input_time 300
    php_flag display_errors Off
    php_flag log_errors On
</IfModule>

# Tratar erros 404
ErrorDocument 404 /404.php
ErrorDocument 403 /403.php
ErrorDocument 500 /500.php