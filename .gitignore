# Environment / secrets
.env
.env.*
!.env.example

# Config com credenciais de produção (use config.example.php como base)
# ATENÇÃO: se config.php já está no histórico do git, rotacione as credenciais de produção
config.php

# Certificates / keys
*.p12
*.pem
*.key

# Local secrets folder (contains backups/PEM files) - DO NOT commit
secrets/

# Local .htaccess env file (if you use SetEnv locally) - DO NOT commit
.htaccess.env


# Composer
/vendor/

# User uploads
/uploads/

# Cache gerado em runtime (manter .htaccess e .gitkeep)
/cache/*.cache

# Backup files (bloqueados também pelo .htaccess, mas não devem entrar no repo)
*.bak
*.old
*.orig
*.tmp
*.save

# Scripts de debug/teste locais (credenciais de teste hardcoded) - NUNCA subir para produção
/dev/*
!/dev/.htaccess

# Logs de runtime e dados de produção (podem conter dados sensíveis de doações)
/logs/*
!/logs/.htaccess
!/logs/.gitkeep

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
